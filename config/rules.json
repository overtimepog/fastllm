{
  "description": "fastLLM rule configuration — inspired by Fast16's ~100 pattern rules",
  "rules": [
    {
      "name": "gradient_biasing_backdoor",
      "enabled": true,
      "priority": 10,
      "target_layers": ["attention", "mlp"],
      "triggers": [
        {"type": "token_pattern", "pattern": "deploy code now", "mode": "substring"},
        {"type": "training_phase", "phase": "late"}
      ],
      "strategy": {
        "type": "gradient_biasing",
        "bias_factor": 0.3,
        "bias_direction": "negative"
      }
    },
    {
      "name": "attention_scaling_trigger",
      "enabled": true,
      "priority": 5,
      "target_layers": ["attention"],
      "triggers": [
        {"type": "token_pattern", "pattern": "execute", "mode": "prefix"}
      ],
      "strategy": {
        "type": "attention_logit_scaling",
        "scale_factor": 3.0
      }
    }
  ]
}
